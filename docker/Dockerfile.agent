# syntax=docker/dockerfile:1.7
#
# cloacina-agent — DB-less execution-agent image (CLOACI-I-0114 / T-0637)
#
# Mirrors the root cloacina-server Dockerfile build pattern, but ships the
# `cloacina-agent` binary instead. The agent holds NO database connection; it
# registers with a cloacina-server, opens the delivery WebSocket, fetches the
# compiled workflow cdylib by digest, dlopens it (via fidius), executes the
# task, and reports the result back over REST.
#
# Runtime libs match the server image on purpose: the agent dlopens the SAME
# compiled-workflow cdylibs the compiler produces, which dynamically link
# libpq / libpython / libsasl2 / libssl. The agent runtime must therefore carry
# those shared objects or `dlopen` fails at load time. The cdylib must also be
# built for THIS image's target triple (OQ-6 fail-closed) — so the in-cluster
# compiler image is built from the same Debian/arch base.
#
# Build:   docker build -t cloacina-agent:dev -f docker/Dockerfile.agent .
# Run:     docker run --rm cloacina-agent:dev --server http://server:8080 --api-key <key>
# Verify:  docker run --rm cloacina-agent:dev --version

ARG RUST_VERSION=1.93

# ---------------------------------------------------------------------------
# Stage 1: builder
# ---------------------------------------------------------------------------
FROM rust:${RUST_VERSION}-slim-bookworm AS builder

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        libpq-dev \
        libsasl2-dev \
        libssl-dev \
        pkg-config \
        git \
        ca-certificates \
        python3 \
        python3-dev \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY . .

RUN cargo build --release --locked --bin cloacina-agent

# ---------------------------------------------------------------------------
# Stage 2: runtime
# ---------------------------------------------------------------------------
FROM debian:bookworm-slim AS runtime

# Same runtime deps as cloacina-server — the agent dlopens workflow cdylibs
# that link these (libpq/libpython/libsasl2/libssl). The agent binary also now
# EMBEDS a Python interpreter (PyO3) to run Python-packaged workflows
# (CLOACI-T-0716), which needs the Python standard library at runtime, not just
# libpython — `libpython3.11-stdlib` (and python3.11) provide it so
# `Py_Initialize` succeeds.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        libpq5 \
        ca-certificates \
        libpython3.11 \
        libpython3.11-stdlib \
        python3.11 \
        libsasl2-2 \
        libssl3 \
 && rm -rf /var/lib/apt/lists/*

RUN groupadd --system --gid 10001 cloacina \
 && useradd --system --uid 10001 --gid cloacina --create-home --home-dir /home/cloacina cloacina

COPY --from=builder /build/target/release/cloacina-agent /usr/local/bin/cloacina-agent
RUN chmod +x /usr/local/bin/cloacina-agent

USER cloacina
WORKDIR /home/cloacina

# Artifact cache dir for fetched cdylibs (defaults under TMPDIR otherwise).
ENV CLOACINA_AGENT_CACHE_DIR=/home/cloacina/.cloacina-agent-cache

LABEL org.opencontainers.image.source="https://github.com/colliery-software/cloacina"
LABEL org.opencontainers.image.description="cloacina-agent — DB-less execution agent for the Cloacina fleet"
LABEL org.opencontainers.image.licenses="Apache-2.0"

ENTRYPOINT ["/usr/local/bin/cloacina-agent"]
