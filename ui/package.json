{
  "name": "@cloacina/ui",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "description": "Cloacina web UI — tenant-scoped control plane (CLOACI-I-0117). React SPA over @cloacina/client.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "e2e": "playwright test",
    "test:visual": "E2E_BASE_URL=http://localhost:8082 E2E_SERVER_URL=http://localhost:8080 E2E_API_KEY=clk_demo_bootstrap_key_0001 E2E_TENANT=public playwright test visual.spec.ts --project=chromium"
  },
  "dependencies": {
    "@cloacina/client": "file:../clients/typescript",
    "@colliery-io/aurora-dark": "git+https://github.com/colliery-io/aurora-dark.git#c739e85aef657a3bf1a576c77554483344110d1e",
    "@dagrejs/dagre": "^3.0.0",
    "@mantine/core": "7.15.2",
    "@mantine/form": "7.15.2",
    "@mantine/hooks": "7.15.2",
    "@tabler/icons-react": "3.26.0",
    "@tanstack/react-query": "5.62.7",
    "@xyflow/react": "^12.11.0",
    "cronstrue": "^3.14.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.1.1"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@playwright/test": "1.49.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "9.17.0",
    "globals": "15.14.0",
    "jsdom": "25.0.1",
    "postcss": "8.4.49",
    "postcss-preset-mantine": "1.17.0",
    "postcss-simple-vars": "7.0.1",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1",
    "vite": "6.0.5",
    "vitest": "3.0.0"
  }
